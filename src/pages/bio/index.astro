---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bio | Tianzhichao (Tim) Hou</title>
    <meta
      name="description"
      content="Biography of Tianzhichao (Tim) Hou, MD, PhD."
    />
  </head>

  <body>
    <Header />

    <main class="bio-page">
      <section class="bio-hero">
        <p class="eyebrow">Bio</p>
        <h1>Tianzhichao (Tim) Hou, MD, PhD</h1>
        <p class="lead">
          Physician-scientist in pediatrics, human genetics, cardiometabolic disease,
          and cancer genomics.
        </p>
      </section>

      <section class="content-grid">
        <article class="bio-card large-card">
          <h2>About</h2>
          <p>
            Tianzhichao (Tim) Hou, MD, PhD, is a physician-scientist and pediatric
            resident at Boston Children’s Hospital / Harvard Medical School. His work
            connects pediatrics, human genetics, cardiometabolic disease, and cancer
            genomics, with a long-term goal of translating genomic discovery into
            clinically meaningful care.
          </p>

          <p>
            He completed medical training at Zhejiang University School of Medicine
            and doctoral research in genetic epidemiology through the University of
            Toronto. His research has used population-scale genomic data, polygenic
            risk scores, Mendelian randomization, and multi-omics approaches to study
            human disease risk, prognosis, and translational opportunities.
          </p>

          <p>
            As a physician-scientist in training, Tim aims to bridge bedside clinical
            questions with human genetics and disease biology, particularly in pediatric
            genetics, metabolic disease, cardiovascular risk, and cancer genomics.
          </p>
        </article>

        <article class="bio-card">
          <h2>Education & Training</h2>

          <div class="timeline-item">
            <span>2026–Present</span>
            <h3>Pediatric Resident</h3>
            <p>Boston Children’s Hospital / Harvard Medical School</p>
          </div>

          <div class="timeline-item">
            <span>2021–2026</span>
            <h3>PhD, Genetic Epidemiology</h3>
            <p>University of Toronto</p>
          </div>

          <div class="timeline-item">
            <span>2013–2021</span>
            <h3>MD</h3>
            <p>Zhejiang University School of Medicine</p>
          </div>
        </article>

        <article class="bio-card">
          <h2>Selected Experience</h2>

          <div class="tag-list">
            <span>Boston Children’s Hospital</span>
            <span>Harvard Medical School</span>
            <span>University of Toronto</span>
            <span>Toronto General Hospital</span>
            <span>SickKids</span>
            <span>Brigham and Women’s Hospital</span>
            <span>Columbia University Irving Medical Center</span>
          </div>
        </article>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    --bg: #f5f5f7;
    --text: #111827;
    --muted: #6b7280;
    --line: rgba(17, 24, 39, 0.12);
    --accent: #0071e3;
    --crimson: #a51c30;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  .bio-page {
    padding: 7rem 6vw;
  }

  .bio-hero {
    max-width: 1080px;
    margin-bottom: 4rem;
  }

  .eyebrow {
    margin: 0 0 1rem;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .bio-hero h1 {
    margin: 0;
    font-size: clamp(2.6rem, 5.5vw, 5.8rem);
    line-height: 0.94;
    letter-spacing: -0.07em;
    font-weight: 800;
  }

  .lead {
    max-width: 780px;
    margin: 2rem 0 0;
    font-size: clamp(1.15rem, 2vw, 1.55rem);
    line-height: 1.55;
    color: var(--muted);
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
    gap: 1.5rem;
  }

  .bio-card {
    padding: clamp(2rem, 4vw, 3rem);
    border-radius: 36px;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid var(--line);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.06);
  }

  .large-card {
    grid-row: span 2;
  }

  .bio-card h2 {
    margin: 0 0 1.4rem;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .bio-card p {
    margin: 0 0 1.2rem;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .timeline-item {
    padding: 1.3rem 0;
    border-top: 1px solid var(--line);
  }

  .timeline-item:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .timeline-item span {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--crimson);
    font-weight: 800;
  }

  .timeline-item h3 {
    margin: 0 0 0.35rem;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
  }

  .timeline-item p {
    margin: 0;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag-list span {
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: #f5f5f7;
    border: 1px solid var(--line);
    color: #374151;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .bio-page {
      padding: 6rem 1.3rem;
    }

    .content-grid {
      grid-template-columns: 1fr;
    }

    .large-card {
      grid-row: auto;
    }
  }
</style>