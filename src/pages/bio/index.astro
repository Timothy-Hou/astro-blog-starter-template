---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bio | Tianzhichao (Tim) Hou</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta
      name="description"
      content="Biography of Tianzhichao (Tim) Hou, MD, PhD — pediatric resident and physician-scientist in human genetics, cardiometabolic disease, and translational medicine."
    />
  </head>

  <body>
    <Header />

    <main class="bio-page">
      <section class="bio-hero">
        <p class="eyebrow">Bio</p>
        <h1>Tianzhichao (Tim) Hou, MD, PhD</h1>

      </section>

      <section class="bio-grid">
        <article class="bio-card about-card">
          <h2>About</h2>
          <p>
            Tianzhichao (Tim) Hou, MD, PhD, is a pediatric resident in the Boston
            Combined Residency Program, training at Boston Children’s Hospital and
            Boston Medical Center. He is pursuing a career as a physician-scientist
            focused on clinical care with human genetics and population evidence.
          </p>

          <p>
            Tim earned his medical degree in China and completed doctoral training in
            medicine and genetics through Shanghai Jiao Tong University and
            the University of Toronto. He completed clinical training across Boston, New York, Toronto, Shanghai, Hangzhou, and Perth.
            His research integrates GWAS/PRS, cohorts, and clinical trials to study cardiometabolic disease, cancer risk,
            and translational medicine.
          </p>

          <p>
            Beyond work, he is interested in swimming. He swam 120 miles during 
            graduate study.
          </p>

          <div class="service-block">
  <h2>Academic Service</h2>

  <div class="timeline-item">
    <span>2024–2026</span>
<h3>
  <a class="bio-link" href="https://genetics-gsa.org/career-development/peer-review-training-program/" target="_blank" rel="noopener noreferrer">
    GSA Journals Peer Review Training Program
  </a>
</h3>
    <p>
      Trained by the Genetics Society of America to strengthen peer-review practice.
    </p>
  </div>

  <div class="timeline-item">
    <span>2024</span>

<h3>
  <a class="bio-link" href="https://www.uhn.ca/PrincessMargaret/Education/Cancer_Campus/biosciences_leadership_development" target="_blank" rel="noopener noreferrer">
    Biosciences Oncology Leadership Development Program
  </a>
</h3>

    <p>
      Trained by Toronto General Hospital in team management and project leadership.
    </p>
  </div>

  <div class="timeline-item">
    <span>2023–Present</span>
    <h3>Academic Society Memberships</h3>
    <p>
      Member of the American Academy of Pediatrics (AAP), American Heart Association (AHA),
      American Society of Human Genetics (ASHG).
    </p>
  </div>

  <div class="timeline-item">
    <span>2022–Present</span>
    <h3>Active Academic Peer Reviewer</h3>
    <p>
      Reviewed more than 60 manuscripts across general medicine, epidemiology,
      genetics, cardiology, and translational research.
    </p>

    <div class="review-tags">
      <span>The BMJ</span>
      <span>Metabolism</span>
      <span>Eur J Epidemiol</span>
      <span>Cardiovasc Diabetol</span>
      <span>J Clin Endocrinol Metab</span>
      <span>Diabetes Obes Metab</span>
    </div>
  </div>

  <div class="timeline-item">
    <span>2022–2023</span>
<h3>
  <a class="bio-link" href="https://x.com/stevesphd/status/1705327195541921810" target="_blank" rel="noopener noreferrer">
    Textbook Translation in Mendelian Randomization
  </a>
</h3>
    <p>
      Translated and reviewed the Chinese version of
      <em>Mendelian Randomization: Methods for Causal Inference Using Genetic Variants</em>.
    </p>
  </div>
</div>

        </article>

        <article class="bio-card">
          <h2>Education</h2>

          <div class="timeline-item">
            <span>2026–Present</span>
            <h3>Pediatric Resident</h3>
            <p>Boston Combined Residency Program</p>
            <p>Boston Children’s Hospital / Boston Medical Center / Harvard Medical School</p>
          </div>

          <div class="timeline-item">
            <span>2023–2025</span>
            <h3>Joint MD/PhD, Medical Biophysics</h3>
            <p>University of Toronto</p>
<p>
  Mentor:
  <a class="bio-link" href="https://www.uhncombiel.com/" target="_blank" rel="noopener noreferrer">
    Geoffrey Liu, MD, MSc
  </a>
</p>          </div>

          <div class="timeline-item">
            <span>2020–2025</span>
            <h3>Joint MD/PhD, Medicine</h3>
            <p>Shanghai Jiao Tong University</p>
<p>
  Mentor:
  <a class="bio-link" href="https://scholar.google.com/citations?user=RABnS_4AAAAJ&hl=en" target="_blank" rel="noopener noreferrer">
    Guang Ning, MD, FACC
  </a>
</p>          </div>

          <div class="timeline-item">
            <span>2015–2020</span>
            <h3>Bachelor of Medicine</h3>
            <p>Zhejiang University School of Medicine</p>
            <p>Graduate summa cum laude; Top 10 Honored Student</p>
          </div>
        </article>

        <article class="bio-card">
          <h2>Selected Achievements</h2>

          <div class="achievement-grid">
            <div>
              <strong>34</strong>
              <span>Peer-reviewed publications</span>
            </div>

            <div>
              <strong>14</strong>
              <span>First-author publications</span>
            </div>

            <div>
              <strong>700+</strong>
              <span>Citations</span>
            </div>

            <div>
              <strong>60+</strong>
              <span>Manuscripts reviewed</span>
            </div>
          </div>

<ul class="achievement-list">
  <li>
    Recipient of National Scholarship, Outstanding Graduate of Shanghai,
    and Princess Margaret Cancer Centre Travel Award.
  </li>

  <li>
    National Golden Prize of the “Challenge Cup” for a public health project on
    non-prescription antibiotic sales across 13 provinces in China.
  </li>
</ul>

        </article>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    --bg: #f5f5f7;
    --text: #111827;
    --muted: #6b7280;
    --line: rgba(17, 24, 39, 0.12);
    --accent: #0071e3;
    --crimson: #a51c30;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  .bio-page {
    padding: 4.5rem 6vw 6rem;
  }

  .bio-hero {
    max-width: 980px;
    margin-bottom: 3rem;
  }
.bio-link {
  color: var(--accent);
  font-weight: 700;
  text-decoration: none;
}

.bio-link:hover {
  text-decoration: underline;
}
  .eyebrow {
    margin: 0 0 0.9rem;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

.bio-hero h1 {
  margin: 0;
  font-size: clamp(1.8rem, 3.7vw, 3.8rem);
  line-height: 1.04;
  letter-spacing: -0.045em;
  font-weight: 800;
}

  .lead {
    max-width: 760px;
    margin: 1.4rem 0 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.65vw, 1.35rem);
    line-height: 1.55;
  }

  .bio-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 1.5rem;
  }

  .bio-card {
    padding: clamp(1.6rem, 3.5vw, 2.6rem);
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--line);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.06);
  }

  .about-card {
    grid-row: span 2;
  }

.bio-card h2 {
  margin: 0 0 1.1rem;
  font-size: clamp(1.25rem, 2.2vw, 1.9rem);
  line-height: 1.08;
  letter-spacing: -0.035em;
  font-weight: 800;
}

  .bio-card p {
    margin: 0 0 1rem;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.72;
  }
.service-block {
  margin-top: 2.2rem;
  padding-top: 1.8rem;
  border-top: 1px solid var(--line);
}

.service-block h2 {
  margin-top: 0;
}

.review-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  margin-top: 0.9rem;
}

.review-tags span {
  padding: 0.45rem 0.7rem;
  border-radius: 999px;
  background: #f5f5f7;
  border: 1px solid var(--line);
  color: #374151;
  font-size: 0.86rem;
  font-weight: 700;
}
  .timeline-item {
    padding: 1.1rem 0;
    border-top: 1px solid var(--line);
  }

  .timeline-item:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .timeline-item span {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--crimson);
    font-size: 0.95rem;
    font-weight: 800;
  }

  .timeline-item h3 {
    margin: 0 0 0.35rem;
    font-size: 1.12rem;
    line-height: 1.25;
    letter-spacing: -0.025em;
  }

  .bio-link {
  color: inherit;
  text-decoration: none;
}

.bio-link:hover {
  color: var(--accent);
  text-decoration: underline;
}

  .timeline-item p {
    margin: 0.15rem 0;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .achievement-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin-bottom: 1.4rem;
  }

  .achievement-grid div {
    padding: 1rem;
    border-radius: 22px;
    background: #f5f5f7;
    border: 1px solid var(--line);
  }

  .achievement-grid strong {
    display: block;
    color: var(--text);
    font-size: clamp(1.7rem, 3vw, 2.5rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .achievement-grid span {
    display: block;
    margin-top: 0.35rem;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.35;
    font-weight: 700;
  }

  .achievement-list {
    margin: 0;
    padding-left: 1.15rem;
    color: var(--muted);
  }

  .achievement-list li {
    margin-bottom: 0.75rem;
    line-height: 1.55;
    font-size: 1rem;
  }
.service-block .bio-link {
  color: inherit !important;
  text-decoration: none;
}

.service-block .bio-link:visited {
  color: inherit !important;
}

.service-block .bio-link:hover {
  color: inherit !important;
  text-decoration: underline;
}
  @media (max-width: 900px) {
    .bio-page {
      padding: 3.5rem 1.3rem 5rem;
    }

    .bio-grid {
      grid-template-columns: 1fr;
    }

    .about-card {
      grid-row: auto;
    }
  }

  @media (max-width: 600px) {
    .achievement-grid {
      grid-template-columns: 1fr;
    }
  }
</style>