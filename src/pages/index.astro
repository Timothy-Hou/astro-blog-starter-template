---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tianzhichao (Tim) Hou, MD, PhD</title>
    <meta
      name="description"
      content="Tim Hou, MD, PhD — Pediatric resident at Boston Children’s Hospital / Harvard Medical School and physician-scientist in genetics, metabolism, and cancer genomics."
    />
  </head>

  <body>
    <Header />

    <main class="site-main">
      <!-- HERO -->
      <section class="section hero-section">
        <div class="hero-content">
          <p class="eyebrow reveal">Tim Hou, MD, PhD</p>

          <h1 class="hero-title reveal">
            Physician-scientist<br />
            in pediatrics, genetics,<br />
            and human disease.
          </h1>

          <p class="hero-subtitle reveal">
            Pediatric Resident at Boston Children’s Hospital / Harvard Medical School.
            My work bridges general pediatrics, cardiometabolic disease, and cancer genomics.
          </p>

          <div class="hero-actions reveal">
            <a class="button primary" href="/cv.pdf">View CV</a>
            <a class="button secondary" href="mailto:med.houtian@gmail.com">Contact Me</a>
          </div>
        </div>

        <div class="hero-visual reveal">
          <div class="portrait-ring">
            <img src="/profile.jpg" alt="Portrait of Tim Hou" />
          </div>
        </div>
      </section>

      <!-- IDENTITY -->
      <section class="section statement-section">
        <div class="statement-wrap">
          <p class="big-line reveal">From clinical questions.</p>
          <p class="big-line reveal">To human genetics.</p>
        </div>
      </section>


      <!-- PUBLICATIONS -->
      <section class="section publications-section">
        <div class="section-heading narrow reveal">
          <p class="eyebrow">Selected Publications</p>
          <h2>Work across genetic cardiology, oncology, and population health.</h2>
          <p>
            Selected research published in journals including Nature Communications,
            Diabetes Care, Lancet Regional Health, and other peer-reviewed journals.
          </p>
        </div>

        <div class="publication-grid">
          <article class="publication-card reveal">
            <p class="journal">Nature Communications</p>
            <h3>Multi-omics and genetic discovery in human disease</h3>
            <a href="#">Read more</a>
          </article>

          <article class="publication-card reveal">
            <p class="journal">Diabetes Care</p>
            <h3>Genetic epidemiology of metabolic and cardiometabolic outcomes</h3>
            <a href="#">Read more</a>
          </article>

          <article class="publication-card reveal">
            <p class="journal">Lancet Regional Health</p>
            <h3>Population-level research in clinical and translational medicine</h3>
            <a href="#">Read more</a>
          </article>
        </div>
      </section>

      <!-- CLINICAL TRAINING -->
      <section class="section clinical-section">
        <div class="clinical-panel reveal">
          <p class="eyebrow">Clinical Training</p>
          <h2>Boston Children’s Hospital / Harvard Medical School</h2>
          <p>
            I am training as a pediatric resident with a long-term goal of becoming
            a physician-scientist who connects bedside care with genetic and
            translational research.
          </p>

          <div class="training-list">
            <span>Boston Children’s Hospital</span>
            <span>Harvard Medical School</span>
            <span>SickKids / Toronto</span>
            <span>Brigham and Women’s Hospital</span>
            <span>Columbia University Irving Medical Center</span>
          </div>
        </div>
      </section>

      <!-- CONTACT -->
      <section class="section contact-section">
        <div class="contact-content reveal">
          <p class="eyebrow">Contact</p>
          <h2>For collaboration, mentorship, or academic inquiries.</h2>
          <a class="email-link" href="mailto:med.houtian@gmail.com">
            med.houtian@gmail.com
          </a>

          <div class="social-links">
            <a href="#">Google Scholar</a>
            <a href="#">PubMed</a>
            <a href="#">ORCID</a>
            <a href="#">LinkedIn</a>
            <a href="#">GitHub</a>
          </div>
        </div>
      </section>
    </main>

    <Footer />

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!reduceMotion) {
        gsap.utils.toArray(".reveal").forEach((element) => {
          gsap.fromTo(
            element,
            {
              opacity: 0,
              y: 40,
            },
            {
              opacity: 1,
              y: 0,
              duration: 1.1,
              ease: "power3.out",
              scrollTrigger: {
                trigger: element,
                start: "top 82%",
                end: "bottom 20%",
                toggleActions: "play none none reverse",
              },
            }
          );
        });


      }
    </script>

    <style>
      :root {
        --bg: #f5f5f7;
        --text: #111827;
        --muted: #6b7280;
        --dark: #050505;
        --dark-text: #f5f5f7;
        --card: rgba(255, 255, 255, 0.78);
        --line: rgba(17, 24, 39, 0.12);
        --accent: #0071e3;
        --crimson: #a51c30;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        overflow-x: hidden;
      }

      .site-main {
        width: 100%;
        overflow-x: hidden;
      }

      .section {
        min-height: 100vh;
        padding: 7rem 6vw;
        display: flex;
        align-items: center;
        position: relative;
      }

      .eyebrow {
        margin: 0 0 1rem;
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .hero-section {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
        gap: 4rem;
        background:
          radial-gradient(circle at 75% 40%, rgba(0, 113, 227, 0.16), transparent 28%),
          linear-gradient(180deg, #ffffff 0%, #f5f5f7 100%);
      }

      .hero-content {
        max-width: 980px;
      }

      .hero-title {
        margin: 0;
        font-size: clamp(2.6rem, 5.5vw, 5.8rem);
        line-height: 0.94;
        letter-spacing: -0.07em;
        font-weight: 800;
      }

      .hero-subtitle {
        max-width: 760px;
        margin: 2rem 0 0;
        font-size: clamp(1.15rem, 2vw, 1.55rem);
        line-height: 1.55;
        color: var(--muted);
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 2rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0.85rem 1.25rem;
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.2s ease, opacity 0.2s ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button.primary {
        background: var(--accent);
        color: white;
      }

      .button.secondary {
        background: rgba(17, 24, 39, 0.08);
        color: var(--text);
      }

      .hero-visual {
        display: flex;
        justify-content: center;
        align-items: center;
      }

      .portrait-ring {
        width: min(340px, 70vw);
        aspect-ratio: 1;
        border-radius: 50%;
        padding: 10px;
        background:
          linear-gradient(#fff, #fff) padding-box,
          linear-gradient(135deg, var(--accent), var(--crimson)) border-box;
        border: 2px solid transparent;
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.12);
      }

      .portrait-ring img {
        width: 100%;
        height: 100%;	
        object-fit: cover;
		object-position: center top;
        border-radius: 50%;
        display: block;
        background: #e5e7eb;
      }

      .statement-section {
        background: #000;
        color: white;
      }

      .statement-wrap {
        max-width: 1100px;
      }

      .big-line {
        margin: 0.15em 0;
        font-size: clamp(3rem, 8vw, 8rem);
        line-height: 0.98;
        letter-spacing: -0.065em;
        font-weight: 800;
      }

      .big-line.muted {
        color: rgba(255, 255, 255, 0.46);
      }

      .horizontal-section {
        min-height: 240vh;
        padding: 0;
        background: #101014;
        color: var(--dark-text);
        align-items: flex-start;
      }

      .sticky-wrap {
        height: 100vh;
        width: 100%;
        padding: 7rem 6vw;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .section-heading {
        max-width: 850px;
        margin-bottom: 3rem;
      }

      .section-heading h2 {
        margin: 0;
        font-size: clamp(2.6rem, 6vw, 6rem);
        line-height: 1;
        letter-spacing: -0.06em;
      }

      .section-heading p:not(.eyebrow) {
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.6;
      }

      .section-heading.narrow {
        max-width: 820px;
      }

      .card-track {
        display: flex;
        gap: 1.25rem;
        width: max-content;
        will-change: transform;
      }

      .research-card {
        width: min(460px, 82vw);
        min-height: 360px;
        padding: 2rem;
        border-radius: 34px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.06));
        border: 1px solid rgba(255, 255, 255, 0.16);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
      }

      .research-card span {
        display: block;
        color: rgba(255, 255, 255, 0.45);
        font-weight: 800;
        margin-bottom: 4rem;
      }

      .research-card h3 {
        margin: 0 0 1rem;
        font-size: 2.1rem;
        letter-spacing: -0.04em;
      }

      .research-card p {
        margin: 0;
        color: rgba(255, 255, 255, 0.68);
        font-size: 1.05rem;
        line-height: 1.65;
      }

      .publications-section {
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
        background: #f5f5f7;
      }

      .publication-grid {
        width: 100%;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.25rem;
        margin-top: 2rem;
      }

      .publication-card {
        min-height: 280px;
        padding: 1.6rem;
        border-radius: 30px;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid var(--line);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.06);
      }

      .journal {
        margin: 0 0 1.5rem;
        color: var(--crimson);
        font-weight: 800;
      }

      .publication-card h3 {
        margin: 0 0 2rem;
        font-size: 1.5rem;
        line-height: 1.18;
        letter-spacing: -0.035em;
      }

      .publication-card a {
        color: var(--accent);
        font-weight: 700;
        text-decoration: none;
      }

      .clinical-section {
        background:
          radial-gradient(circle at 20% 30%, rgba(165, 28, 48, 0.16), transparent 30%),
          #ffffff;
      }

      .clinical-panel {
        width: min(1100px, 100%);
        padding: clamp(2rem, 5vw, 4rem);
        border-radius: 42px;
        background: rgba(245, 245, 247, 0.82);
        border: 1px solid var(--line);
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.08);
      }

      .clinical-panel h2,
      .contact-content h2 {
        margin: 0;
        font-size: clamp(2.8rem, 6vw, 6rem);
        line-height: 1;
        letter-spacing: -0.06em;
      }

      .clinical-panel p {
        max-width: 780px;
        margin-top: 1.5rem;
        color: var(--muted);
        font-size: 1.2rem;
        line-height: 1.65;
      }

      .training-list {
        margin-top: 2rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .training-list span {
        padding: 0.75rem 1rem;
        border-radius: 999px;
        background: white;
        border: 1px solid var(--line);
        color: #374151;
        font-weight: 700;
      }

      .contact-section {
        background: #050505;
        color: white;
      }

      .contact-content {
        max-width: 1000px;
      }

      .email-link {
        display: inline-block;
        margin-top: 2rem;
        font-size: clamp(1.5rem, 3vw, 2.5rem);
        color: white;
        text-decoration: none;
        border-bottom: 2px solid rgba(255, 255, 255, 0.35);
      }

      .social-links {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 2rem;
      }

      .social-links a {
        color: rgba(255, 255, 255, 0.72);
        text-decoration: none;
        font-weight: 700;
      }

      .social-links a:hover {
        color: white;
      }

      @media (max-width: 900px) {
        .section {
          padding: 6rem 1.3rem;
        }

        .hero-section {
          grid-template-columns: 1fr;
          gap: 2rem;
        }

        .hero-visual {
          justify-content: flex-start;
        }

        .publication-grid {
          grid-template-columns: 1fr;
        }

        .sticky-wrap {
          padding: 6rem 1.3rem;
        }
      }

      @media (max-width: 700px) {
        .horizontal-section {
          min-height: auto;
          padding: 6rem 1.3rem;
        }

        .sticky-wrap {
          height: auto;
          padding: 0;
          overflow: visible;
        }

        .card-track {
          width: 100%;
          flex-direction: column;
          transform: none !important;
        }

        .research-card {
          width: 100%;
          min-height: auto;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      }
    </style>
  </body>
</html>