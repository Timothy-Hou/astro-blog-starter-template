<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Publications | Tianzhichao (Tim) Hou</title>
    <meta
      name="description"
      content="Publications and presentations by Tianzhichao Hou in genetic epidemiology, Mendelian randomization, polygenic risk scores, multi-omics, diabetes, cardiometabolic disease, cancer epidemiology, and longevity."
    />
<link rel="icon" type="image/png" href="/favicon.png" />
</head>

  <body>
    <Header />

    <main class="pub-page">
      <section class="pub-hero">
        <p class="eyebrow">Publications</p>
        <h1>Research publications</h1>
        <p class="lead">
          Genetic epidemiology · Polygenic risk scores · Multi-omics · Diabetes and cardiometabolic disease ·
           Cancer epidemiology · Human longevity
        </p>
      </section>

      <section class="pub-section">
        <h2>Peer-Reviewed Publications</h2>

        <div class="pub-list">
          {publications.map((pub) => (
            <article class="pub-item">
              <div class="pub-year">{pub.year}</div>
              <div class="pub-content">
                <h3>
                  <a href={pub.link} target="_blank" rel="noopener noreferrer">
                    {pub.title}
                  </a>
                </h3>
                <p class="authors">{pub.authors}</p>
                <p class="journal">
                  {pub.venue}{pub.details ? ` · ${pub.details}` : ""}
                </p>
              </div>
            </article>
          ))}
        </div>
      </section>

<section class="pub-section">
  <h2>Presentations & Abstracts</h2>

  <div class="pub-list">
    {presentations.map((pub) => (
      <article class="pub-item">
        <div class="pub-year">{pub.year}</div>
        <div class="pub-content">
          <h3>
            {pub.link ? (
              <a href={pub.link} target="_blank" rel="noopener noreferrer">
                {pub.title}
              </a>
            ) : (
              <span>{pub.title}</span>
            )}
          </h3>
          <p class="authors">{pub.authors}</p>
          <p class="journal">
            {pub.venue}{pub.details ? ` · ${pub.details}` : ""}
          </p>
        </div>
      </article>
    ))}
  </div>
</section>
<section class="pub-section">
  <h2>Science Communication & Public Writing</h2>

  <div class="pub-list">
    {scienceWriting.map((item) => (
      <article class="pub-item">
        <div class="pub-year">{item.year}</div>
        <div class="pub-content">
          <h3>
            <a href={item.link} target="_blank" rel="noopener noreferrer">
              {item.titleEn}
            </a>
          </h3>

          <p class="science-title-zh">
            <a href={item.link} target="_blank" rel="noopener noreferrer">
              {item.titleZh}
            </a>
          </p>

          <p class="authors">
            Popular science article · Reading: {item.reading} · Reposts: {item.repost} · Likes: {item.likes}
          </p>
        </div>
      </article>
    ))}
  </div>
</section>
    </main>

    <Footer />
  </body>
</html>

<style>
  body {
    margin: 0;
    background: #f5f5f7;
    color: #111827;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  .pub-page {
    padding: 5.5rem 6vw;
  }

  .pub-hero {
    max-width: 980px;
    margin-bottom: 3rem;
  }

  .eyebrow {
    margin: 0 0 0.9rem;
    color: #0071e3;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pub-hero h1 {
    margin: 0;
    font-size: clamp(2.1rem, 4.2vw, 4rem);
    line-height: 1.02;
    letter-spacing: -0.055em;
    font-weight: 800;
  }

.lead {
  max-width: 760px;
  margin-top: 1.1rem;
  color: #6b7280;
  font-size: clamp(0.9rem, 1.15vw, 1.05rem);
  line-height: 1.55;
}

  .pub-section {
    max-width: 1050px;
    margin-bottom: 2rem;
    padding: clamp(1.75rem, 4vw, 3rem);
    border-radius: 32px;
    background: white;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.06);
  }

.pub-section h2 {
  margin: 0 0 1.15rem;
  font-size: clamp(1.3rem, 2.1vw, 1.85rem);
  line-height: 1.12;
  letter-spacing: -0.035em;
}

  .pub-list {
    display: grid;
    gap: 0;
  }

  .pub-item {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 1.2rem;
    padding: 1.25rem 0;
    border-top: 1px solid rgba(17, 24, 39, 0.12);
  }

  .pub-item:first-of-type {
    border-top: none;
  }

  .pub-year {
    color: #6b7280;
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

.pub-content h3 {
  margin: 0 0 0.4rem;
  font-size: clamp(0.92rem, 1.08vw, 1.05rem);
  line-height: 1.42;
  letter-spacing: -0.015em;
  font-weight: 700;
}
.pub-content h3 span {
  color: #111827;
}
  .pub-content h3 a {
    color: #111827;
    text-decoration: none;
  }

  .pub-content h3 a:hover {
    color: #0071e3;
  }
.science-title-zh {
  margin: -0.15rem 0 0.25rem;
  font-size: 0.88rem;
  line-height: 1.45;
  font-weight: 650;
}

.science-title-zh a {
  color: #374151;
  text-decoration: none;
}

.science-title-zh a:hover {
  color: #0071e3;
}
.authors {
  margin: 0 0 0.2rem;
  color: #4b5563;
  font-size: 0.86rem;
  line-height: 1.45;
}

.journal {
  margin: 0;
  color: #a51c30;
  font-size: 0.86rem;
  font-weight: 700;
  line-height: 1.45;
}

  @media (max-width: 700px) {
    .pub-page {
      padding: 4.8rem 5vw;
    }

    .pub-item {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .pub-year {
      font-size: 0.86rem;
    }
  }
</style>