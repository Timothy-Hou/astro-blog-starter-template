---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Publications | Tianzhichao (Tim) Hou</title>
    <meta
      name="description"
      content="Publications, abstracts, conference presentations, and science communication by Tianzhichao Hou."
    />
  </head>

  <body>
    <Header />

    <main class="pub-page">
      <section class="pub-hero">
        <p class="eyebrow">Publications</p>
        <h1>Research, presentations, and science communication.</h1>
        <p class="lead">
          Selected peer-reviewed publications, conference abstracts, presentations,
          and public-facing scientific writing.
        </p>
      </section>

      <section class="pub-section">
        <h2>Peer-Reviewed Publications</h2>

        <article class="pub-item">
          <p class="journal">Nature Communications</p>
          <h3>Multi-omics and genetic discovery in human disease</h3>
          <p>Selected representative publication. Add authors, year, DOI, and link here.</p>
        </article>

        <article class="pub-item">
          <p class="journal">Diabetes Care</p>
          <h3>Genetic epidemiology of metabolic and cardiometabolic outcomes</h3>
          <p>Selected representative publication. Add authors, year, DOI, and link here.</p>
        </article>

        <article class="pub-item">
          <p class="journal">Lancet Regional Health</p>
          <h3>Population-level research in clinical and translational medicine</h3>
          <p>Selected representative publication. Add authors, year, DOI, and link here.</p>
        </article>
      </section>

      <section class="pub-section">
        <h2>Abstracts & Conference Presentations</h2>

        <article class="pub-item">
          <p class="journal">AACR / ASCO / AAP / Other Conferences</p>
          <h3>Conference abstracts and scientific presentations</h3>
          <p>Add abstract title, conference name, year, and presentation type here.</p>
        </article>
      </section>

      <section class="pub-section">
        <h2>Science Communication / Popular Science</h2>

        <article class="pub-item">
          <p class="journal">Public-facing writing</p>
          <h3>Science communication and educational writing</h3>
          <p>Add popular science articles, educational essays, media pieces, or public writing here.</p>
        </article>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  body {
    margin: 0;
    background: #f5f5f7;
    color: #111827;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  .pub-page {
    padding: 6rem 6vw;
  }

  .pub-hero {
    max-width: 1050px;
    margin-bottom: 4rem;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: #0071e3;
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pub-hero h1 {
    margin: 0;
    font-size: clamp(3rem, 7vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .lead {
    max-width: 760px;
    margin-top: 1.6rem;
    color: #6b7280;
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    line-height: 1.55;
  }

  .pub-section {
    max-width: 1000px;
    margin-bottom: 2rem;
    padding: clamp(2rem, 5vw, 3.5rem);
    border-radius: 36px;
    background: white;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.06);
  }

  .pub-section h2 {
    margin: 0 0 1.5rem;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .pub-item {
    padding: 1.5rem 0;
    border-top: 1px solid rgba(17, 24, 39, 0.12);
  }

  .pub-item:first-of-type {
    border-top: none;
  }

  .journal {
    margin: 0 0 0.5rem;
    color: #a51c30;
    font-weight: 800;
  }

  .pub-item h3 {
    margin: 0 0 0.6rem;
    font-size: 1.35rem;
    letter-spacing: -0.03em;
  }

  .pub-item p {
    margin: 0;
    color: #4b5563;
    font-size: 1.05rem;
    line-height: 1.65;
  }
</style>